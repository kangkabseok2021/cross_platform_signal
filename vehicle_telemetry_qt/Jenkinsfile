pipeline {
    agent {
        docker { image 'ubuntu:24.04' }
    }

    environment {
        DEBIAN_FRONTEND = 'noninteractive'
    }

    stages {
        stage('Install Dependencies') {
            steps {
                sh '''
                    apt-get update -qq
                    apt-get install -y --no-install-recommends \
                        cmake ninja-build g++ python3 python3-pip \
                        qt6-base-dev qt6-declarative-dev qt6-charts-dev \
                        libssl-dev ca-certificates git curl
                    pip3 install --quiet requests pytest
                '''
            }
        }

        stage('Build — EMA Tests (no Qt)') {
            steps {
                dir('vehicle_telemetry_qt') {
                    sh '''
                        cmake -B build_ema -DCMAKE_BUILD_TYPE=Release \
                              -DBUILD_VT_HTTP=OFF \
                              -DCMAKE_POLICY_DEFAULT_CMP0135=NEW
                        cmake --build build_ema --target test_ema -j$(nproc)
                    '''
                }
            }
        }

        stage('Unit Tests — 6 EMA GoogleTests') {
            steps {
                dir('vehicle_telemetry_qt') {
                    sh 'ctest --test-dir build_ema --output-on-failure -V'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'vehicle_telemetry_qt/build_ema/**/*gtest*.xml'
                }
            }
        }

        stage('Build — Headless HTTP Server') {
            steps {
                dir('vehicle_telemetry_qt') {
                    sh '''
                        cmake -B build_http -DCMAKE_BUILD_TYPE=Release \
                              -DBUILD_VT_HTTP=ON \
                              -DCMAKE_POLICY_DEFAULT_CMP0135=NEW
                        cmake --build build_http --target vehicle_telemetry_headless -j$(nproc)
                    '''
                }
            }
        }

        stage('Integration Tests — 5 pytest REST tests') {
            steps {
                dir('vehicle_telemetry_qt') {
                    sh '''
                        TELEMETRY_BINARY=build_http/vehicle_telemetry_headless \
                        pytest tests_python/ -v --tb=short
                    '''
                }
            }
        }

        stage('Build — Qt GUI (offscreen)') {
            steps {
                dir('vehicle_telemetry_qt') {
                    sh '''
                        cmake -B build_qt -DCMAKE_BUILD_TYPE=Release \
                              -DBUILD_VT_HTTP=ON \
                              -DCMAKE_POLICY_DEFAULT_CMP0135=NEW
                        cmake --build build_qt --target vehicle_telemetry -j$(nproc) || true
                    '''
                }
            }
        }
    }

    post {
        failure {
            echo 'Build failed — check console output above'
        }
        always {
            cleanWs()
        }
    }
}
